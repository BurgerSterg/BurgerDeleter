<Page x:Class="BurgerDeleter.Views.NetworkView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

  <Page.Resources>

    <!-- AccentBrush run/apply button -->
    <Style x:Key="RunBtn" TargetType="Button">
      <Setter Property="Background"          Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground"          Value="White"/>
      <Setter Property="BorderThickness"     Value="0"/>
      <Setter Property="Padding"             Value="14,8"/>
      <Setter Property="FontSize"            Value="12"/>
      <Setter Property="FontWeight"          Value="SemiBold"/>
      <Setter Property="Cursor"              Value="Hand"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Opacity" Value="0.88"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="b" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Transparent icon / ghost button (eye, close) -->
    <Style x:Key="GhostBtn" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="6,3"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}" Opacity="0.75">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Opacity" Value="1"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Stat card border -->
    <Style x:Key="StatCard" TargetType="Border">
      <Setter Property="Background"      Value="{DynamicResource SurfaceElevatedBrush}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="10"/>
      <Setter Property="Padding"         Value="16,14"/>
      <Setter Property="Margin"          Value="4"/>
    </Style>

    <!-- Command card border -->
    <Style x:Key="CmdCard" TargetType="Border">
      <Setter Property="Background"      Value="{DynamicResource SurfaceElevatedBrush}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="10"/>
      <Setter Property="Padding"         Value="18,16"/>
      <Setter Property="Margin"          Value="4"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- page header -->
      <RowDefinition Height="*"/>     <!-- scrollable content -->
      <RowDefinition Height="Auto"/>  <!-- terminal (collapsible) -->
    </Grid.RowDefinitions>

    <!-- ══ Page header ══ -->
    <Border Grid.Row="0"
            Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,20">
      <TextBlock Text="🌐  Network Monitor"
                 FontSize="22" FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>
    </Border>

    <!-- ══ Main scrollable content ══ -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="24,20,24,20">

        <!-- ── Section 1: Live Stats ── -->
        <TextBlock Text="LIVE STATS"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,10"/>

        <UniformGrid Columns="4" Margin="0,0,0,28">

          <!-- Download speed -->
          <Border Style="{StaticResource StatCard}" Background="#1A22C55E">
            <StackPanel>
              <TextBlock Text="↓  Download"
                         FontSize="11" FontWeight="SemiBold"
                         Foreground="#22C55E" Margin="0,0,0,8"/>
              <TextBlock x:Name="DownloadLabel"
                         Text="—"
                         FontSize="24" FontWeight="Bold"
                         Foreground="#22C55E"/>
            </StackPanel>
          </Border>

          <!-- Upload speed -->
          <Border Style="{StaticResource StatCard}" Background="#1AEF4444">
            <StackPanel>
              <TextBlock Text="↑  Upload"
                         FontSize="11" FontWeight="SemiBold"
                         Foreground="#EF4444" Margin="0,0,0,8"/>
              <TextBlock x:Name="UploadLabel"
                         Text="—"
                         FontSize="24" FontWeight="Bold"
                         Foreground="#EF4444"/>
            </StackPanel>
          </Border>

          <!-- Network IP (Local) with eye toggle — visible by default -->
          <Border Style="{StaticResource StatCard}"
                  ToolTip="Your IP on your home network. Only visible to devices on the same router. Not a privacy risk.">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Network IP (Local)"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        Content="👁"
                        Style="{StaticResource GhostBtn}"
                        VerticalAlignment="Center"
                        Click="ToggleLocalIp_Click"/>
              </Grid>

              <!-- Text starts empty; code-behind fills it on load -->
              <TextBlock Grid.Row="1"
                         x:Name="LocalIpDisplay"
                         Text=""
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>

              <!-- Hidden by default because Local IP is revealed on load -->
              <TextBlock Grid.Row="2"
                         x:Name="LocalIpHint"
                         Text="Hidden — click 👁 to reveal"
                         FontSize="10" Foreground="#EF4444"
                         Visibility="Hidden"
                         Margin="0,5,0,0"/>
            </Grid>
          </Border>

          <!-- Public IP with eye toggle — hidden by default -->
          <Border Style="{StaticResource StatCard}"
                  ToolTip="Your real internet IP address. This is what others on the internet see. Keep this hidden when streaming or screen sharing.">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Public IP (Hide when streaming)"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button HorizontalAlignment="Right"
                        Content="👁"
                        Style="{StaticResource GhostBtn}"
                        VerticalAlignment="Center"
                        Click="TogglePublicIp_Click"/>
              </Grid>

              <TextBlock Grid.Row="1"
                         x:Name="PublicIpDisplay"
                         Text="••••••••"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>

              <TextBlock Grid.Row="2"
                         x:Name="PublicIpHint"
                         Text="Hidden — click 👁 to reveal"
                         FontSize="10" Foreground="#EF4444"
                         Margin="0,5,0,0"/>
            </Grid>
          </Border>

        </UniformGrid>

        <!-- ── Section 2: Network Tools ── -->
        <TextBlock Text="NETWORK TOOLS"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,10"/>

        <UniformGrid Columns="2">

          <!-- 1. Flush DNS -->
          <Border Style="{StaticResource CmdCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Flush DNS"
                         FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Grid.Row="1"
                         Text="Clears your DNS cache. Fixes websites not loading or showing old content. Safe to run anytime."
                         TextWrapping="Wrap" FontSize="12" Margin="0,6,0,14"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Button Grid.Row="2"
                      x:Name="FlushDnsBtn"
                      Content="▶  Run"
                      Style="{StaticResource RunBtn}"
                      Click="FlushDns_Click"/>
            </Grid>
          </Border>

          <!-- 2. Release IP -->
          <Border Style="{StaticResource CmdCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Release IP"
                         FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Grid.Row="1"
                         Text="Tells your PC to give up its current IP address from the router. Run this before Renew if your connection is stuck."
                         TextWrapping="Wrap" FontSize="12" Margin="0,6,0,14"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Button Grid.Row="2"
                      x:Name="ReleaseIpBtn"
                      Content="▶  Run"
                      Style="{StaticResource RunBtn}"
                      Click="ReleaseIp_Click"/>
            </Grid>
          </Border>

          <!-- 3. Renew IP -->
          <Border Style="{StaticResource CmdCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Renew IP"
                         FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Grid.Row="1"
                         Text="Requests a fresh IP address from your router. Fixes 'No Internet' issues after Release."
                         TextWrapping="Wrap" FontSize="12" Margin="0,6,0,14"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Button Grid.Row="2"
                      x:Name="RenewIpBtn"
                      Content="▶  Run"
                      Style="{StaticResource RunBtn}"
                      Click="RenewIp_Click"/>
            </Grid>
          </Border>

          <!-- 4. Reset Network Stack -->
          <Border Style="{StaticResource CmdCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Reset Network Stack"
                         FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Grid.Row="1"
                         Text="Full reset of Windows networking. Use this if nothing else works — requires a restart."
                         TextWrapping="Wrap" FontSize="12" Margin="0,6,0,14"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Button Grid.Row="2"
                      x:Name="ResetStackBtn"
                      Content="▶  Run"
                      Style="{StaticResource RunBtn}"
                      Click="ResetStack_Click"/>
            </Grid>
          </Border>

          <!-- 5. Test DNS Speed -->
          <Border Style="{StaticResource CmdCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Test DNS Speed"
                         FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Grid.Row="1"
                         Text="Pings Cloudflare (1.1.1.1) and Google (8.8.8.8) DNS servers and shows which is faster for you."
                         TextWrapping="Wrap" FontSize="12" Margin="0,6,0,14"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Border Grid.Row="2"
                      x:Name="DnsSpeedResultCard"
                      Visibility="Collapsed"
                      Background="{DynamicResource BackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10,8"
                      Margin="0,0,0,10">
                <TextBlock x:Name="DnsSpeedResult"
                           TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </Border>
              <Button Grid.Row="3"
                      x:Name="TestDnsBtn"
                      Content="▶  Run"
                      Style="{StaticResource RunBtn}"
                      Click="TestDns_Click"/>
            </Grid>
          </Border>

          <!-- 6. Change DNS -->
          <Border Style="{StaticResource CmdCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Change DNS"
                         FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Grid.Row="1"
                         Text="Switch your DNS provider for faster browsing."
                         TextWrapping="Wrap" FontSize="12" Margin="0,6,0,12"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <ComboBox x:Name="DnsCombo"
                        Grid.Row="2"
                        Margin="0,0,0,10"
                        FontSize="12">
                <ComboBoxItem Content="Cloudflare  (1.1.1.1)" Tag="1.1.1.1" IsSelected="True"/>
                <ComboBoxItem Content="Google  (8.8.8.8)"     Tag="8.8.8.8"/>
                <ComboBoxItem Content="Default ISP  (DHCP)"   Tag="dhcp"/>
              </ComboBox>
              <Button Grid.Row="3"
                      x:Name="ApplyDnsBtn"
                      Content="▶  Apply"
                      Style="{StaticResource RunBtn}"
                      Click="ApplyDns_Click"/>
              <TextBlock Grid.Row="4"
                         x:Name="DnsStatusLabel"
                         Visibility="Collapsed"
                         TextWrapping="Wrap" FontSize="11"
                         Margin="0,8,0,0"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
          </Border>

        </UniformGrid>

      </StackPanel>
    </ScrollViewer>

    <!-- ══ Terminal output (collapsible, pinned to bottom) ══ -->
    <Border x:Name="TerminalSection"
            Grid.Row="2"
            Visibility="Collapsed"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Terminal header bar -->
        <Border Grid.Row="0" Background="#161B22" Padding="16,7">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="⬛"  FontSize="10" Foreground="#58A6FF" VerticalAlignment="Center" Margin="0,0,6,0"/>
              <TextBlock x:Name="TerminalTitle"
                         Text="Last Command Output"
                         FontSize="11" FontWeight="Bold"
                         Foreground="#8B949E" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="✕"
                    HorizontalAlignment="Right"
                    Style="{StaticResource GhostBtn}"
                    Foreground="#8B949E"
                    FontSize="13"
                    Click="CloseTerminal_Click"/>
          </Grid>
        </Border>

        <!-- Terminal output -->
        <ScrollViewer Grid.Row="1"
                      x:Name="TerminalScroll"
                      MaxHeight="200"
                      Background="#0D1117"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <TextBox x:Name="TerminalOutput"
                   Background="Transparent"
                   Foreground="#C9D1D9"
                   FontFamily="Consolas"
                   FontSize="11"
                   IsReadOnly="True"
                   TextWrapping="Wrap"
                   BorderThickness="0"
                   Padding="16,10"
                   AcceptsReturn="True"
                   VerticalAlignment="Top"/>
        </ScrollViewer>
      </Grid>
    </Border>

  </Grid>
</Page>
