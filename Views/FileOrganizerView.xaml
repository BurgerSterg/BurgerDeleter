<Page x:Class="BurgerDeleter.Views.FileOrganizerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Title="File Organizer">

    <Page.Resources>

        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"
                                        Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OrganizeBtnStyle" TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Padding" Value="28,14"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="PathBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeView row style -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="IsExpanded" Value="True"/>
        </Style>

    </Page.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- folder picker -->
            <RowDefinition Height="*"/>     <!-- preview + rules columns -->
            <RowDefinition Height="Auto"/>  <!-- progress section -->
            <RowDefinition Height="Auto"/>  <!-- organize button + status -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="File Organizer"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Automatically sort files in any folder into subfolders by type. Preview first, then apply."
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Folder picker -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="FolderPathBox"
                     Grid.Column="0"
                     Style="{StaticResource PathBoxStyle}"
                     Margin="0,0,8,0"/>

            <Button x:Name="BrowseBtn"
                    Grid.Column="1"
                    Content="📁  Browse"
                    Style="{StaticResource ActionBtnStyle}"
                    Padding="16,10"
                    Margin="0,0,8,0"
                    Click="Browse_Click"/>

            <Button x:Name="PreviewBtn"
                    Grid.Column="2"
                    Content="🔍  Preview"
                    Style="{StaticResource ActionBtnStyle}"
                    Padding="16,10"
                    Click="Preview_Click"/>
        </Grid>

        <!-- Two-column body: Preview TreeView | Rules -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Preview TreeView -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock Text="PREVIEW — FILES WILL BE MOVED TO"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="PreviewTree"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="8"/>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <TextBlock x:Name="PreviewEmptyLabel"
                               Grid.Row="1"
                               Text="Click Preview to see how files will be organized."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13"/>
                </Grid>
            </Border>

            <!-- Rules panel -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="SORTING RULES"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,12"/>

                    <!-- Rule rows -->
                    <ItemsControl>
                        <ItemsControl.Items>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="📷  Images" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=".jpg  .jpeg  .png  .gif  .webp  .bmp  .svg"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="🎬  Videos" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=".mp4  .mkv  .mov  .avi  .wmv  .flv"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="🎵  Audio" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=".mp3  .wav  .flac  .aac  .ogg"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="📄  Documents" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=".pdf  .doc  .docx  .xls  .xlsx  .ppt  .pptx  .txt"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="📦  Archives" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=".zip  .rar  .7z  .iso  .tar  .gz"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="⚙️  Installers" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=".exe  .msi"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="💻  Code" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=".py  .js  .ts  .cs  .html  .css  .json  .xml"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="📁  Other" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Everything else"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </ItemsControl.Items>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Progress section (collapsed until organizing) -->
        <Border x:Name="ProgressSection"
                Grid.Row="3"
                Visibility="Collapsed"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,10" Margin="0,12,0,0">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="ProgressStatusLabel"
                               HorizontalAlignment="Left"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"/>
                    <TextBlock x:Name="ProgressPercentLabel"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="12" FontWeight="Bold"/>
                </Grid>
                <Border CornerRadius="4" ClipToBounds="True" Height="8"
                        Background="{DynamicResource SurfaceElevatedBrush}">
                    <ProgressBar x:Name="OrganizeProgressBar"
                                 Height="8" Maximum="100" Value="0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Bottom bar -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusLabel"
                       Grid.Column="0"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" VerticalAlignment="Center"
                       Text="Choose a folder and click Preview to get started."/>

            <Button x:Name="OrganizeBtn"
                    Grid.Column="1"
                    Content="✅  Organize Now"
                    Style="{StaticResource OrganizeBtnStyle}"
                    IsEnabled="False"
                    Click="Organize_Click"/>
        </Grid>
    </Grid>
</Page>
