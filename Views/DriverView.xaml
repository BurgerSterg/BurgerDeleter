<Page x:Class="BurgerDeleter.Views.DriverView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Title="Driver Scanner">

  <Page.Resources>

    <!-- Filter pill -->
    <Style x:Key="FilterPill" TargetType="ToggleButton">
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Background"      Value="{DynamicResource SurfaceElevatedBrush}"/>
      <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="14,5"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Margin"          Value="0,0,8,0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="b"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="20" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Scan button -->
    <Style x:Key="ScanBtnStyle" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="22,11"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Opacity" Value="0.88"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="b" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Download / accent action button -->
    <Style x:Key="DownloadBtnStyle" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="16,8"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Opacity" Value="0.82"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="b" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Secondary / outline button (Copy Links) -->
    <Style x:Key="SecondaryBtnStyle" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource SurfaceElevatedBrush}"/>
      <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="16,8"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Opacity" Value="0.80"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Driver card DataTemplate ── -->
    <DataTemplate x:Key="DriverCardTemplate">
      <Border Margin="0,0,0,10"
              Background="{DynamicResource SurfaceElevatedBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>   <!-- accent strip -->
            <ColumnDefinition Width="*"/>   <!-- body -->
          </Grid.ColumnDefinitions>

          <!-- Coloured left accent strip -->
          <Border Grid.Column="0" CornerRadius="10,0,0,10">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="#EF4444"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Status}" Value="Outdated">
                    <Setter Property="Background" Value="#F59E0B"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
          </Border>

          <!-- Card body -->
          <Grid Grid.Column="1" Margin="18,14,18,14">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: checkbox + device name + status badge -->
            <Grid Grid.Row="0" Margin="0,0,0,5">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- checkbox -->
                <ColumnDefinition Width="*"/>      <!-- device name -->
                <ColumnDefinition Width="Auto"/>   <!-- status badge -->
              </Grid.ColumnDefinitions>

              <CheckBox Grid.Column="0"
                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"/>

              <TextBlock Grid.Column="1"
                         Text="{Binding FriendlyName}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center"
                         ToolTip="{Binding DeviceName}"/>

              <!-- Status badge — colour and label via Style.Triggers -->
              <Border Grid.Column="2"
                      CornerRadius="4" Padding="8,3"
                      Margin="12,0,0,0" VerticalAlignment="Center">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="#EF4444"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Status}" Value="Outdated">
                        <Setter Property="Background" Value="#F59E0B"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock FontSize="11" FontWeight="Bold" Foreground="White">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="Critical"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Outdated">
                          <Setter Property="Text" Value="Outdated"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </Border>
            </Grid>

            <!-- Row 1: friendly date -->
            <TextBlock Grid.Row="1"
                       Text="{Binding FriendlyDate}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,3"/>

            <!-- Row 2: provider · version -->
            <TextBlock Grid.Row="2"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,12">
              <Run Text="{Binding Provider}"/>
              <Run Text=" · "/>
              <Run Text="{Binding DriverVersion}" FontFamily="Consolas"/>
            </TextBlock>

            <!-- Row 3: status reason + individual download button -->
            <Grid Grid.Row="3">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0"
                         Text="{Binding StatusReason}"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center"
                         Margin="0,0,12,0"/>

              <Button Grid.Column="1"
                      Content="↓  Download Update"
                      Style="{StaticResource DownloadBtnStyle}"
                      Tag="{Binding UpdateUrl}"
                      Click="DownloadUpdate_Click"
                      VerticalAlignment="Center"/>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </DataTemplate>

  </Page.Resources>

  <!-- ══ Root ══ -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- 0: header -->
      <RowDefinition Height="Auto"/>  <!-- 1: filter toolbar + select all -->
      <RowDefinition Height="Auto"/>  <!-- 2: summary card -->
      <RowDefinition Height="Auto"/>  <!-- 3: progress bar -->
      <RowDefinition Height="*"/>     <!-- 4: driver card list -->
      <RowDefinition Height="Auto"/>  <!-- 5: batch action bar -->
      <RowDefinition Height="Auto"/>  <!-- 6: status bar -->
    </Grid.RowDefinitions>

    <!-- ── Header ── -->
    <Border Grid.Row="0"
            Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,20">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="🔧  Driver Scanner"
                     FontSize="22" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="Outdated drivers cause crashes, poor performance, and security vulnerabilities."
                     FontSize="12" Margin="0,4,0,0"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
        <Button x:Name="ScanBtn"
                Grid.Column="1"
                Content="🔍  Scan Drivers"
                Style="{StaticResource ScanBtnStyle}"
                VerticalAlignment="Center"
                Click="ScanBtn_Click"/>
      </Grid>
    </Border>

    <!-- ── Filter toolbar + Select All ── -->
    <Border Grid.Row="1"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Filter pills -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <ToggleButton x:Name="FilterAll"
                        Content="All"
                        Style="{StaticResource FilterPill}"
                        IsChecked="True"
                        Checked="FilterAll_Checked"/>
          <ToggleButton x:Name="FilterCritical"
                        Content="🔴  Critical"
                        Style="{StaticResource FilterPill}"
                        Checked="FilterType_Checked"
                        Unchecked="Filter_Unchecked"/>
          <ToggleButton x:Name="FilterOutdated"
                        Content="🟡  Outdated"
                        Style="{StaticResource FilterPill}"
                        Checked="FilterType_Checked"
                        Unchecked="Filter_Unchecked"/>
        </StackPanel>

        <!-- Select All checkbox -->
        <CheckBox x:Name="SelectAllCheckbox"
                  Grid.Column="1"
                  Content="Select All"
                  FontSize="12"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                  VerticalAlignment="Center"
                  Checked="SelectAll_Checked"
                  Unchecked="SelectAll_Unchecked"/>
      </Grid>
    </Border>

    <!-- ── Summary card ── -->
    <Border x:Name="SummaryCard"
            Grid.Row="2"
            Visibility="Collapsed"
            Margin="24,16,24,0"
            CornerRadius="10"
            Padding="20,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="SummaryIcon"
                   Grid.Column="0"
                   Text="⚠"
                   FontSize="22"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"/>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock x:Name="SummaryTitle" FontSize="15" FontWeight="Bold"/>
          <TextBlock x:Name="SummarySubtitle" FontSize="12" Margin="0,2,0,0" Opacity="0.85"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Progress bar ── -->
    <Border x:Name="ProgressSection"
            Grid.Row="3"
            Visibility="Collapsed"
            Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,1"
            Padding="24,10"
            Margin="0,14,0,0">
      <StackPanel>
        <TextBlock x:Name="ProgressLabel"
                   Text="Scanning…"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,6"/>
        <ProgressBar x:Name="ScanProgress"
                     Height="5"
                     IsIndeterminate="True"
                     Background="{DynamicResource BorderBrush}"
                     Foreground="{DynamicResource AccentBrush}">
          <ProgressBar.Template>
            <ControlTemplate TargetType="ProgressBar">
              <Border Background="{TemplateBinding Background}" CornerRadius="3"
                      Height="{TemplateBinding Height}">
                <Border x:Name="PART_Track" CornerRadius="3">
                  <Border x:Name="PART_Indicator"
                          Background="{TemplateBinding Foreground}"
                          CornerRadius="3"
                          HorizontalAlignment="Left"/>
                </Border>
              </Border>
            </ControlTemplate>
          </ProgressBar.Template>
        </ProgressBar>
      </StackPanel>
    </Border>

    <!-- ── Driver card list ── -->
    <ScrollViewer Grid.Row="4"
                  VerticalScrollBarVisibility="Auto"
                  Padding="24,16,24,8">
      <ItemsControl x:Name="DriverList"
                    ItemTemplate="{StaticResource DriverCardTemplate}"/>
    </ScrollViewer>

    <!-- ── Batch action bar (visible when ≥1 driver selected) ── -->
    <Border x:Name="BatchBar"
            Grid.Row="5"
            Visibility="Collapsed"
            Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="0,2,0,0"
            Padding="24,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock x:Name="BatchLabel"
                     Text="0 drivers selected"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Column="1"
                x:Name="CopyLinksBtn"
                Content="📋  Copy All Links"
                Style="{StaticResource SecondaryBtnStyle}"
                Click="CopyAllLinks_Click"
                VerticalAlignment="Center"/>

        <!-- spacer col 2 -->

        <Button Grid.Column="3"
                x:Name="OpenAllBtn"
                Content="⬇  Open All Download Pages"
                Style="{StaticResource DownloadBtnStyle}"
                Click="OpenAllPages_Click"
                VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- ── Status bar ── -->
    <Border Grid.Row="6"
            Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="24,10">
      <TextBlock x:Name="StatusBar"
                 Text="Click Scan Drivers to check for outdated drivers."
                 FontSize="12"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>
    </Border>

  </Grid>
</Page>
