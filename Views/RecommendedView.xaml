<Page x:Class="BurgerDeleter.Views.RecommendedView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Title="Recommended">

    <Page.Resources>

        <Style x:Key="ThemedListViewItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="rowBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter
                                Columns="{Binding Path=View.Columns,
                                          RelativeSource={RelativeSource AncestorType=ListView}}"
                                Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rowBorder" Property="Background"
                                        Value="{DynamicResource SurfaceElevatedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="rowBorder" Property="Background"
                                        Value="{DynamicResource SurfaceElevatedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScanBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"
                                        Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteBtnStyle" TargetType="Button" BasedOn="{StaticResource ScanBtnStyle}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Page.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Recommended"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Unused apps, bloated caches, and leftover installers — curated cleanup suggestions."
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Controls bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="StartScanBtn"
                    Grid.Column="0"
                    Content="🎯  Scan for Recommendations"
                    Style="{StaticResource ScanBtnStyle}"
                    Click="StartScan_Click"/>

            <TextBlock x:Name="ScanStatusLabel"
                       Grid.Column="1"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center"
                       Margin="16,0" Text="Click Scan to find cleanup opportunities."/>

            <!-- Before/After counter cards -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="14,8" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="SELECTED TO REMOVE"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="SelectedSizeLabel"
                                   Text="0 GB"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="14,8">
                    <StackPanel>
                        <TextBlock Text="FREE AFTER DELETE"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="FreeAfterLabel"
                                   Text="-- GB"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Results list -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                ClipToBounds="True">
            <ListView x:Name="ResultsList"
                      Background="Transparent"
                      BorderThickness="0"
                      ItemContainerStyle="{StaticResource ThemedListViewItem}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource ThemedColumnHeader}">

                        <!-- Checkbox -->
                        <GridViewColumn Width="44">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Safety dot + Icon + Name -->
                        <GridViewColumn Header="Name" Width="240">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                ToolTip="{Binding SafetyReason}">
                                        <Border x:Name="SafetyDot"
                                                Width="8" Height="8" CornerRadius="4"
                                                Background="#3EC46D"
                                                Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CategoryIcon}"
                                                   FontSize="14" Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="NameText" Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="13" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding SafetyLevel}" Value="Caution">
                                            <Setter TargetName="SafetyDot" Property="Background"
                                                    Value="{DynamicResource WarningBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SafetyLevel}" Value="Danger">
                                            <Setter TargetName="SafetyDot" Property="Background"
                                                    Value="{DynamicResource DangerBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SafetyLevel}" Value="ManagedElsewhere">
                                            <Setter TargetName="SafetyDot" Property="Background"
                                                    Value="{DynamicResource TextMutedBrush}"/>
                                            <Setter TargetName="NameText"  Property="Foreground"
                                                    Value="{DynamicResource TextMutedBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Category badge -->
                        <GridViewColumn Header="Category" Width="106">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="CatBadge"
                                            CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Left"
                                            Background="#374151">
                                        <TextBlock x:Name="CatText"
                                                   Text="{Binding RecommendationCategory}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RecommendationCategory}" Value="Unused App">
                                            <Setter TargetName="CatBadge" Property="Background" Value="#6D28D9"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecommendationCategory}" Value="Cache">
                                            <Setter TargetName="CatBadge" Property="Background" Value="#D97706"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecommendationCategory}" Value="Downloads">
                                            <Setter TargetName="CatBadge" Property="Background" Value="#2563EB"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecommendationCategory}" Value="Duplicate">
                                            <Setter TargetName="CatBadge" Property="Background" Value="#DB2777"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecommendationCategory}" Value="Update Cache">
                                            <Setter TargetName="CatBadge" Property="Background" Value="#0D9488"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecommendationCategory}" Value="Log File">
                                            <Setter TargetName="CatBadge" Property="Background" Value="#4B5563"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Why recommended -->
                        <GridViewColumn Header="Why Recommended" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RecommendationReason}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Size -->
                        <GridViewColumn Header="Size" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeDisplay}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Path -->
                        <GridViewColumn Header="Path" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullPath}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Bottom bar -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="SelectionHintLabel"
                       Grid.Column="0"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" VerticalAlignment="Center"
                       Text="Check items above to select them for removal."/>

            <Button x:Name="DeleteSelectedBtn"
                    Grid.Column="1"
                    Content="🗑  Delete Selected"
                    Style="{StaticResource DeleteBtnStyle}"
                    Click="DeleteSelected_Click"
                    IsEnabled="False"/>
        </Grid>
    </Grid>
</Page>
