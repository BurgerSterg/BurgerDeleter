<Page x:Class="BurgerDeleter.Views.MemoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Title="Memory Optimizer">

    <Page.Resources>

        <Style x:Key="OptimizeBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"
                                        Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtnStyle" TargetType="Button" BasedOn="{StaticResource OptimizeBtnStyle}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ActionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

    </Page.Resources>

    <!-- Outer scroll so the page works at any window height -->
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="*"/>      <!-- scrollable body -->
            <RowDefinition Height="Auto"/>   <!-- bottom bar -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Memory Optimizer"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Free up RAM and clear junk slowing your system down."
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ===== SCROLLABLE BODY ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- RAM stat cards -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total RAM -->
                    <Border Grid.Column="0" Style="{StaticResource ActionCardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL RAM"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="TotalRamLabel"
                                       Text="— GB"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Used RAM -->
                    <Border Grid.Column="2" Style="{StaticResource ActionCardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="USED RAM"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="UsedRamLabel"
                                       Text="— GB"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Available RAM -->
                    <Border Grid.Column="4" Style="{StaticResource ActionCardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="AVAILABLE RAM"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="AvailRamLabel"
                                       Text="— GB"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RAM usage bar -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="RAM Usage"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="RamPctLabel"
                                       HorizontalAlignment="Right"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>
                        <Border CornerRadius="4" ClipToBounds="True" Height="10"
                                Background="{DynamicResource SurfaceElevatedBrush}">
                            <ProgressBar x:Name="RamUsageBar"
                                         Height="10" Maximum="100" Value="0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource SuccessBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Section label -->
                <TextBlock Text="ACTIONS"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,0,0,10"/>

                <!-- Action cards: 2-column uniform grid -->
                <UniformGrid Columns="2" Margin="0,0,0,0">

                    <!-- 1. Trim Process Working Sets -->
                    <Border Style="{StaticResource ActionCardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="TrimCheck" IsChecked="True" Margin="0,0,0,6">
                                <TextBlock Text="Trim Process Working Sets"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </CheckBox>
                            <TextBlock Text="Forces Windows to move idle process memory to the pagefile, immediately freeing RAM. Safe, instant."
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 2. Clear Standby Memory -->
                    <Border Style="{StaticResource ActionCardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="StandbyCheck" IsChecked="True" Margin="0,0,0,6">
                                <TextBlock Text="Clear Standby Memory"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </CheckBox>
                            <TextBlock Text="Flushes the standby list so fresh RAM is available. Uses NtSetSystemInformation. Requires administrator."
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 3. Clear Temp Files -->
                    <Border Style="{StaticResource ActionCardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="TempCheck" IsChecked="True" Margin="0,0,0,6">
                                <TextBlock Text="Clear Temp Files"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </CheckBox>
                            <TextBlock Text="Deletes everything in %TEMP% and C:\Windows\Temp that isn't locked. Same as running disk cleanup."
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 4. Flush DNS Cache -->
                    <Border Style="{StaticResource ActionCardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="DnsCheck" IsChecked="True" Margin="0,0,0,6">
                                <TextBlock Text="Flush DNS Cache"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </CheckBox>
                            <TextBlock Text="Clears the DNS resolver cache. Fixes slow lookups. Runs ipconfig /flushdns."
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 5. Clear Clipboard -->
                    <Border Style="{StaticResource ActionCardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="ClipboardCheck" IsChecked="True" Margin="0,0,0,6">
                                <TextBlock Text="Clear Clipboard"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </CheckBox>
                            <TextBlock Text="Wipes clipboard memory instantly. Runs Clipboard.Clear()."
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 6. Stop Background Apps -->
                    <Border Style="{StaticResource ActionCardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="KillAppsCheck" IsChecked="False"
                                      Margin="0,0,0,6"
                                      Checked="KillAppsCheck_Checked"
                                      Unchecked="KillAppsCheck_Unchecked">
                                <TextBlock Text="Stop Background Apps"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </CheckBox>
                            <TextBlock Text="Lists non-essential background processes over 50 MB so you can pick which to stop."
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Background process sub-list (shown when Stop Background Apps is checked) -->
                <Border x:Name="ProcessListSection"
                        Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Margin="0,4,10,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" MaxHeight="240"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Background="{DynamicResource SurfaceElevatedBrush}"
                              Margin="0,0,0,0">
                            <Border CornerRadius="8,8,0,0" Padding="12,8">
                                <Grid>
                                    <TextBlock Text="BACKGROUND PROCESSES  (≥ 50 MB)"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button HorizontalAlignment="Right"
                                            Content="↻ Refresh"
                                            Style="{StaticResource SmallBtnStyle}"
                                            Click="RefreshProcesses_Click"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ListView x:Name="ProcessListView"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="8,4">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding MemoryMB, StringFormat={}{0} MB}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Progress section (collapsed until running) -->
                <Border x:Name="ProgressSection"
                        Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16,12" Margin="0,10,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock x:Name="ProgressStatusLabel"
                                       HorizontalAlignment="Left"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="ProgressStepLabel"
                                       HorizontalAlignment="Right"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Grid>
                        <Border CornerRadius="4" ClipToBounds="True" Height="8"
                                Background="{DynamicResource SurfaceElevatedBrush}">
                            <ProgressBar x:Name="OptimizeProgressBar"
                                         Height="8" Maximum="100" Value="0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Results card (collapsed until done) -->
                <Border x:Name="ResultsCard"
                        Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource SuccessBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16,14" Margin="0,10,10,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="BEFORE" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2"/>
                            <TextBlock x:Name="ResultBeforeLabel"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="→"
                                   FontSize="20" Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="16,0"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="AFTER" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2"/>
                            <TextBlock x:Name="ResultAfterLabel"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="3"
                                Background="#1A3D2B" CornerRadius="6"
                                Padding="14,8" Margin="24,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="ResultFreedLabel"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#22C55E"/>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== BOTTOM BAR ===== -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusLabel"
                       Grid.Column="0"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" VerticalAlignment="Center"
                       Text="Select actions above and click Optimize Now."/>

            <Button x:Name="OptimizeBtn"
                    Grid.Column="1"
                    Content="⚡  Optimize Now"
                    Style="{StaticResource OptimizeBtnStyle}"
                    Click="Optimize_Click"/>
        </Grid>
    </Grid>
</Page>
